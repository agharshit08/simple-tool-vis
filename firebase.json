{
  "hosting": {
    "site": "simple-tool-visualisation",
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "remoteconfig": {
    "template": "remote_config.json"
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "HistoriaVis",
        "supportEmail": "harshit.agrawal@gmail.com",
        "authorizedRedirectUris": [
          "http://localhost"
        ]
      }
    }
  }
}
